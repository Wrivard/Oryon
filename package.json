{
  "name": "oryon",
  "productName": "Oryon",
  "version": "0.1.11",
  "description": "Oryon — Multi-agent Electron IDE piloting Claude Code CLI",
  "author": "Wrivard <wrivard@kua.quebec>",
  "homepage": "https://github.com/Wrivard/Oryon",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "publish:win": "electron-vite build && electron-builder --win --publish always",
    "release:stable": "npm version patch && git push --follow-tags",
    "release:stable:local": "npm version patch && npm run publish:win",
    "release:dev": "node scripts/bump-dev.mjs && npm run publish:win"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@huggingface/transformers": "^4.2.0",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "monaco-editor": "^0.52.2",
    "motion": "^12.40.0",
    "uiohook-napi": "^1.5.5",
    "uuid": "^10.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "zustand": "^5.0.0"
  }
}
